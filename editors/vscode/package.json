{
  "name": "mumei",
  "displayName": "Mumei Language",
  "description": "Language support for Mumei (.mm) — formally verified programming language with Z3",
  "version": "0.3.0",
  "license": "Apache-2.0",
  "publisher": "mumei-lang",
  "icon": "icon.png",
  "keywords": ["mumei", "formal-verification", "z3", "proof", "language"],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "bugs": {
    "url": "https://github.com/mumei-lang/mumei/issues"
  },
  "homepage": "https://github.com/mumei-lang/mumei",
  "repository": {
    "type": "git",
    "url": "https://github.com/mumei-lang/mumei"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages", "Linters"],
  "activationEvents": [
    "onLanguage:mumei"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "mumei",
        "aliases": ["Mumei", "mumei"],
        "extensions": [".mm"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mumei",
        "scopeName": "source.mumei",
        "path": "./syntaxes/mumei.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "mumei.showIntentDrift",
        "title": "Mumei: Show Intent Drift"
      },
      {
        "command": "mumei.showSpecCodeMapping",
        "title": "Mumei: Show Spec-Code Mapping"
      }
    ],
    "configuration": {
      "title": "Mumei",
      "properties": {
        "mumei.serverPath": {
          "type": "string",
          "default": "mumei",
          "description": "Path to the mumei binary (used for LSP)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "node tests/validate-extension-assets.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
