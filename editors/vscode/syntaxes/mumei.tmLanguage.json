{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Mumei",
  "scopeName": "source.mumei",

  "comment": "Order matters: TextMate uses first-match-wins. atom-definition and type-definition must precede their generic keyword counterparts so that 'atom foo' and 'struct Bar' capture the name.",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#atom-definition" },
    { "include": "#type-definition" },
    { "include": "#declaration-keywords" },
    { "include": "#control-keywords" },
    { "include": "#builtin-types" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.mumei",
          "match": "//.*$"
        },
        {
          "name": "comment.block.mumei",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.mumei",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.mumei",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.mumei",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.mumei",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "atom-definition": {
      "patterns": [
        {
          "match": "\\b(atom)\\s+(\\w+)",
          "captures": {
            "1": { "name": "keyword.control.mumei" },
            "2": { "name": "entity.name.function.mumei" }
          }
        }
      ]
    },
    "type-definition": {
      "patterns": [
        {
          "match": "\\b(type|struct|enum|trait|impl)\\s+(\\w+)",
          "captures": {
            "1": { "name": "keyword.other.mumei" },
            "2": { "name": "entity.name.type.mumei" }
          }
        }
      ]
    },
    "control-keywords": {
      "patterns": [
        {
          "name": "keyword.control.mumei",
          "match": "\\b(atom|atom_ref|requires|ensures|body|if|else|while|match|let|import|as|perform|acquire|release|for|forall|exists|where|invariant|decreases|effects|effect_pre|effect_post|resources|ref|mut|call|priority|mode|includes|parent|chan|send|recv|cancel|task_group|task|max_unroll|fn)\\b"
        }
      ]
    },
    "declaration-keywords": {
      "patterns": [
        {
          "name": "keyword.other.mumei",
          "match": "\\b(type|struct|enum|trait|impl|effect|resource|extern|trusted|unverified|async|await|consume|contract|law|exclusive|shared)\\b"
        }
      ]
    },
    "builtin-types": {
      "patterns": [
        {
          "name": "support.type.mumei",
          "match": "\\b(i64|i32|u64|u32|f64|f32|bool|Str|String)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.mumei",
          "match": "(&&|\\|\\||\\|>|==|!=|>=|<=|=>|->|[+\\-*/%<>!])"
        }
      ]
    }
  }
}
