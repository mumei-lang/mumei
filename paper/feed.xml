---
layout: null
sitemap: false
feed_title: "Mumei Language Technical Paper"
feed_description: "Technical paper for the Mumei mathematical proof-driven programming language."
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="{{ site.lang | default: 'en' | xml_escape }}">
  <title>{{ page.feed_title | xml_escape }}</title>
  <subtitle>{{ page.feed_description | xml_escape }}</subtitle>
  <link href="{{ '/paper/feed.xml' | absolute_url }}" rel="self" type="application/atom+xml" />
  <link href="{{ '/paper/' | absolute_url }}" rel="alternate" type="text/html" />
  <id>{{ '/paper/feed.xml' | absolute_url }}</id>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <author>
    <name>{{ site.author | default: site.title | xml_escape }}</name>
  </author>
  {% assign paper_page = site.pages | where: "url", "/paper/" | first %}
  <entry>
    <title>{{ paper_page.title | default: page.feed_title | xml_escape }}</title>
    <link href="{{ '/paper/' | absolute_url }}" rel="alternate" type="text/html" />
    <id>{{ '/paper/' | absolute_url }}</id>
    <updated>{{ site.time | date_to_xmlschema }}</updated>
    <summary>{{ paper_page.description | default: page.feed_description | strip_html | xml_escape }}</summary>
  </entry>
</feed>
