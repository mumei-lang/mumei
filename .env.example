# ===========================================
# Mumei Self-Healing / MCP Server 設定
# ===========================================

# --- LLM Provider 設定 ---

# パターン1: Ollama ローカル (推奨: 無料、プライバシー保護)
# 前提: `ollama pull qwen3.5` または `ollama pull qwen3.5:small` を実行済み
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen3.5
# LLM_MODEL=qwen3.5:small  # 軽量版 (VRAM 8GB以下)

# パターン2: 外部APIベース（個人のクラウドサーバーや外部サービスなど（例）Alibaba Cloud DashScope etc...）
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# パターン3: vLLM ローカルサーバー
# 前提: `vllm serve Qwen/Qwen3.5-7B --port 8000` を実行済み
# LLM_API_KEY=dummy
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL=Qwen/Qwen3.5-7B

# パターン4: OpenAI (従来通り)
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# LLM_MODEL=gpt-4o

# --- 後方互換 (LLM_API_KEY が未設定の場合にフォールバック) ---
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
