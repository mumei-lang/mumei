# ===========================================
# Mumei Self-Healing / MCP Server Config
# ===========================================

# --- LLM Provider Config ---

# Pattern 1: Ollama local (Docker Compose recommended: free, privacy-preserving)
# Prerequisite: `docker compose up -d` -> `docker exec mumei-ollama ollama pull qwen3.5`
#              (or lightweight: `docker exec mumei-ollama ollama pull qwen3.5:small`)
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen3.5
# LLM_MODEL=qwen3.5:small  # lightweight (VRAM <= 8GB)

# Pattern 2: External API (personal cloud server or external service, e.g. Alibaba Cloud DashScope)
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# Pattern 3: vLLM local server
# Prerequisite: `vllm serve Qwen/Qwen3.5-7B --port 8000` already running
# LLM_API_KEY=dummy
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL=Qwen/Qwen3.5-7B

# Pattern 4: OpenAI (legacy)
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# LLM_MODEL=gpt-4o

# --- Backward compatibility (fallback when LLM_API_KEY is not set) ---
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# --- Visualizer Sync Config ---
# true: Also copy report.json to visualizer/ on MCP tool execution
#       -> Real-time monitoring via Streamlit dashboard (streamlit run visualizer/app.py)
# false (default): MCP response only. No Visualizer. AI-only workflow
# ENABLE_VISUALIZER_SYNC=true
